# ─────────────────────────────────────────────────────────────────────────────
# Calvis Dispatch — environment
# Copy to `.env.local` and fill in. Nothing here is required to RUN the app:
# with no keys set, DEMO=1 replays frozen fixtures and cached traces.
# ─────────────────────────────────────────────────────────────────────────────

# ── Run mode ────────────────────────────────────────────────────────────────
# 1 = replay frozen nights + cached LLM traces. No API key needed, fully
#     deterministic. This is what a reviewer runs. Default when unset.
# 0 = live agent calls against LLM_PROVIDER below.
DEMO=1


# ── Database ────────────────────────────────────────────────────────────────
# One Drizzle schema, two targets.
#
# DATABASE_URL  — the live app + your dev work. Neon serverless Postgres.
#                 Get from https://console.neon.tech → Connection string.
#                 Must include ?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/calvis?sslmode=require

# EVAL_DATABASE_URL — the eval harness only. Must be LOCAL: the harness does
#                 thousands of inserts per run and network round-trips to Neon
#                 would make it unusably slow. Leave as-is to use embedded
#                 Postgres (no install), or point at a local postgres if you
#                 have one running.
EVAL_DATABASE_URL=pglite://.data/eval


# ── LLM providers ───────────────────────────────────────────────────────────
# Two distinct jobs, deliberately different models.

# (1) NIGHT GENERATION — offline only. Writes fixtures to evals/nights/*.json,
#     which are committed. Never called at runtime or during eval.
OPENAI_API_KEY=sk-...
NIGHT_GEN_MODEL=gpt-4o

# (2) THE AGENT — reasons about incidents at runtime. Behind a pluggable
#     provider interface; switch providers without touching agent code.
#     Options: deepseek | openai | anthropic
LLM_PROVIDER=deepseek

DEEPSEEK_API_KEY=sk-...
# Two-tier routing: cheap model triages the firehose, strong model handles
# ambiguous or high-consequence incidents.
AGENT_MODEL_FAST=deepseek-chat
AGENT_MODEL_STRONG=deepseek-reasoner

# Only needed if LLM_PROVIDER is switched to one of these.
# ANTHROPIC_API_KEY=sk-ant-...


# ── Agent behaviour ─────────────────────────────────────────────────────────
# Escalate from FAST to STRONG when the fast model's confidence sits in this
# ambiguous band, or when the incident is tier 3+.
AGENT_ESCALATE_BAND_LOW=0.35
AGENT_ESCALATE_BAND_HIGH=0.70

# Hard ceiling on live spend per eval run. Aborts rather than silently burning.
AGENT_MAX_USD_PER_RUN=2.00


# ── Eval ────────────────────────────────────────────────────────────────────
# Published practice is N>=10 with bootstrap CIs (FRONTIER.md Axis B).
EVAL_RUNS=10
EVAL_BASE_SEED=42
